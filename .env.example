# =============================================
# KOSH - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================

# --- Database ---
POSTGRES_HOST=kosh-database
POSTGRES_DB=kosh
POSTGRES_USER=stockpick_user
POSTGRES_PASSWORD=change_me_in_production

# --- Flask ---
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=change_me_to_a_long_random_string

# --- Optional: SSO Integration ---
# Only needed if integrating with an external SSO provider
SSO_SECRET_KEY=

# --- Optional: External Database URL ---
# Overrides individual POSTGRES_* vars if set
# DATABASE_URL=postgresql://user:password@host:5432/kosh
